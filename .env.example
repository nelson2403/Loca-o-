# ============================================================================
# Sistema de Gestão de Locações — Variáveis de Ambiente
# ----------------------------------------------------------------------------
# Copie este arquivo para `.env.local` e preencha com valores reais.
# Nunca faça commit de `.env.local`.
# ============================================================================

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
# URL base da aplicação (usada em metadados, links de e-mail/WhatsApp e webhooks).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Supabase
# Painel: https://supabase.com/dashboard/project/_/settings/api
# -----------------------------------------------------------------------------
# URL do projeto Supabase (público).
NEXT_PUBLIC_SUPABASE_URL="https://SEU-PROJETO.supabase.co"

# Chave anônima (público) — respeita RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY="COLE_AQUI_A_ANON_KEY"

# Chave de serviço (SECRETA) — bypassa RLS. Usada só no servidor (webhooks, jobs).
SUPABASE_SERVICE_ROLE_KEY="COLE_AQUI_A_SERVICE_ROLE_KEY"

# -----------------------------------------------------------------------------
# ASAAS (cobranças, boletos e PIX)
# Sandbox: https://sandbox.asaas.com | Produção: https://www.asaas.com
# -----------------------------------------------------------------------------
# URL base da API. Sandbox por padrão.
ASAAS_BASE_URL="https://api-sandbox.asaas.com/v3"
# Produção: "https://api.asaas.com/v3"

# Chave de API do ASAAS.
ASAAS_API_KEY=""

# Token para validar os webhooks recebidos do ASAAS (defina o mesmo no painel).
ASAAS_WEBHOOK_TOKEN=""

# -----------------------------------------------------------------------------
# Evolution API (WhatsApp)
# -----------------------------------------------------------------------------
# URL da instância da Evolution API.
EVOLUTION_API_URL=""

# API key global da Evolution API.
EVOLUTION_API_KEY=""

# Nome da instância (número/sessão) usada para enviar mensagens.
EVOLUTION_INSTANCE=""

# -----------------------------------------------------------------------------
# Automações / Cron
# -----------------------------------------------------------------------------
# Segredo compartilhado para proteger as rotas de automação (Vercel Cron).
# Gere um valor aleatório forte, ex.: `openssl rand -hex 32`.
CRON_SECRET=""
